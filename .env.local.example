# Supabase – get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Maps – https://console.cloud.google.com
# Enable: Maps JavaScript API + Places API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# Optional: Cloud Map ID for Advanced Markers (create in Map Styles)
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID

# hCaptcha – https://www.hcaptcha.com (free tier)
# The default test sitekey 10000000-ffff-ffff-ffff-000000000001 works in development
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001

# eSewa merchant ID (test: EPAYTEST, production: get from eSewa merchant dashboard)
NEXT_PUBLIC_ESEWA_MERCHANT_ID=EPAYTEST

# Khalti secret key – server-side only, get from Khalti merchant dashboard
KHALTI_SECRET_KEY=your_khalti_secret_key_here

# Site URL for payment return redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000
